#!/usr/bin/env bash
# =============================================================================
# CR380 - Docker Lab — Configuration centrale / Central configuration
# =============================================================================
#
# FR: Modifier ce fichier pour mettre à jour les versions d'images, les noms
#     de conteneurs et les délais d'attente avant chaque session de cours.
# EN: Edit this file to update image versions, container names, and timeouts
#     before each class session.
# =============================================================================

# -----------------------------------------------------------------------------
# Images Docker / Docker images
# -----------------------------------------------------------------------------
IMAGE_NGINX="nginx"
IMAGE_NGINX_ALPINE="nginx:alpine"
IMAGE_DEBIAN="debian"
IMAGE_UBUNTU="ubuntu:jammy"
IMAGE_PHP="php:8.2-apache-bookworm"
IMAGE_HELLO="hello-world"

# -----------------------------------------------------------------------------
# Noms de conteneurs / Container names
# -----------------------------------------------------------------------------
CT_DEBIAN="debianCT"
CT_NGINX="nginxCT"
CT_NGINX_SLIM="nginxCT-slim"
CT_DRUPAL="drupal10"
CT_DRUPAL_EP="drupal10x"
CT_COPY="copyCT"

# -----------------------------------------------------------------------------
# Tags d'images construites / Built image tags
# -----------------------------------------------------------------------------
IMG_STRUCTURE="monimage:structure"
IMG_SLIM="monimage:structure-slim"
IMG_MULTISTAGE="monimage:multi-stage"
IMG_ENTRYPOINT="img:entrypoint"

# -----------------------------------------------------------------------------
# Build arguments / Arguments de construction
# -----------------------------------------------------------------------------
DRUPAL_VERSION="10.0.0"
PHP_VERSION="8.2-apache-bookworm"
UBUNTU_VERSION="jammy"

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
PORT_NGINX=80
PORT_NGINX_ALT=81
PORT_DRUPAL=8090
PORT_ENTRYPOINT=8091

# -----------------------------------------------------------------------------
# Volumes
# -----------------------------------------------------------------------------
VOL_NAME="www_data"
VOL_MOUNT="/var/www/html"

# -----------------------------------------------------------------------------
# Délais d'attente / Timeouts (seconds)
# -----------------------------------------------------------------------------
TIMEOUT_DEFAULT=30
TIMEOUT_APT=180
TIMEOUT_BUILD=600
TIMEOUT_PULL=180
TIMEOUT_CONTAINER_READY=30

# -----------------------------------------------------------------------------
# Prérequis / Prerequisites
# -----------------------------------------------------------------------------
MIN_DISK_GB=10

# -----------------------------------------------------------------------------
# GitBook
# -----------------------------------------------------------------------------
GITBOOK_BASE_URL="https://polytechnique-montreal.gitbook.io/cr380/uypezSjfF3TINgWe4QZx"
